# =============================================================================
# TalentCircle Content Pipeline — Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores reales:
#   cp .env.example .env
#
# NUNCA subas el archivo .env al repositorio.
# El .gitignore ya lo excluye.
# =============================================================================


# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/talentcircle
DATABASE_USER=talentcircle
DATABASE_PASSWORD=talentcircle


# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379


# -----------------------------------------------------------------------------
# JWT
# Debe tener mínimo 32 caracteres. Genera uno con:
#   openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=cambia-esto-por-un-secreto-de-minimo-32-chars


# -----------------------------------------------------------------------------
# LLM — Proveedor de IA
# Valores posibles: openai | anthropic
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI
# Obtén tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# Anthropic Claude
# Obtén tu clave en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-sonnet-20240229


# -----------------------------------------------------------------------------
# LINKEDIN
#
# ACCESS TOKEN:
#   1. Ve a https://www.linkedin.com/developers/apps y crea una app
#   2. Activa el producto "Share on LinkedIn" (scope: w_member_social)
#   3. Genera un token OAuth 2.0 con ese scope
#   Guía rápida: https://learn.microsoft.com/en-us/linkedin/shared/authentication/authorization-code-flow
#
# PERSON ID:
#   Llama a GET https://api.linkedin.com/v2/me con tu token.
#   El campo "id" del response es tu PERSON_ID (ej: "ABC123xyz")
#   Ejemplo con curl:
#     curl -H "Authorization: Bearer TU_TOKEN" https://api.linkedin.com/v2/me
# -----------------------------------------------------------------------------
LINKEDIN_ACCESS_TOKEN=AQV...
LINKEDIN_PERSON_ID=ABC123xyz


# -----------------------------------------------------------------------------
# FRONTEND
# URL del frontend para configurar CORS en el backend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# SPRING PROFILE
# Valores: dev | prod
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
